# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/astramile?schema=public"

# Server
PORT=4000
NODE_ENV=development

# Frontend origin(s) — comma-separated for multiple
CORS_ORIGIN=http://localhost:3000

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN=7d

# Seed admin credentials (used by `npm run seed` / `seed:prod`).
# The admin is upserted every run; demo content is only seeded on first run.
# Set SEED_FORCE=true to re-upsert the demo content over existing rows.
SEED_ADMIN_EMAIL=admin@astramile.local
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME="AstraMile Admin"
# SEED_FORCE=true

# Uploads — relative to backend/
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10
